# =========================================
# AMS - Audit Management System
# Git Ignore Rules
# =========================================

# ---------- Environment / Secrets ----------
.env
.env.*
!.env.example
!.env.*.example

backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ---------- Python / FastAPI ----------
backend/.venv/
backend/venv/
backend/env/
.venv/
venv/
env/

__pycache__/
*/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

.pytest_cache/
.mypy_cache/
.ruff_cache/
backend/.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ---------- Alembic / DB local files ----------
*.db
*.sqlite
*.sqlite3
*.dump
*.bak

# ---------- Node / Next.js ----------
node_modules/
frontend/node_modules/

.next/
frontend/.next/
out/
frontend/out/
dist/
frontend/dist/
build/
frontend/build/

.npm/
.pnpm-store/
.yarn/
.yarn-cache/

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
uvicorn.log

# ---------- Runtime / Cache ----------
.cache/
.tmp/
tmp/
temp/
*.pid
*.seed

# ---------- OS Files ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo

# ---------- Local backups ----------
backup*/
*_backup*/
frontend_backup*/
backend_backup*/
backup_target_pages_before_toolbar_fix_*/
frontend_backup_after_*/

# ---------- Generated / Scratch Documentation ----------
everything*.md
everything_full.txt
common module existing all page refactor.md

# ---------- Personal / Generated Office Files ----------
*.docx
*.pptx
*.xlsx
~$*

# ---------- Generated Images / Temporary Assets ----------
Gemini_Generated_Image_*.png
generated_*.png
screenshot_*.png

# ---------- Keep important project files ----------
!.gitignore
!README.md
!.env.example
!docker-compose.yml
!docker-compose.prod.yml

# Gitignore local backup
.gitignore.backup
